# SmartComparison-Tool Frontend Environment

# API Base URL — leave empty for dev (Vite proxy handles routing to backend)
# Set to the full backend URL for production builds (e.g. http://localhost:3001)
VITE_API_BASE_URL=

# Supabase configuration (required for auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
