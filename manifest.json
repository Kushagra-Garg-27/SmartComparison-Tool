{
  "manifest_version": 3,
  "name": "SmartCompare AI",
  "version": "1.0.0",
  "description": "An intelligent e-commerce comparison tool powered by Gemini.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "tabs"],
  "host_permissions": ["https://*/*"],
  "action": {
    "default_title": "Open SmartCompare"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.tsx"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}